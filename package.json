{
  "name": "reitrn-warehouse",
  "version": "1.0.0",
  "description": "reitrn. Warehouse — one desktop station app for the reitrn warehouse: inspection, scanning, webcam capture and built-in label printing. Pointed at Lite (portal) or Hub (ReturnHub) by config.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.reitrn.warehouse",
    "productName": "reitrn Warehouse",
    "copyright": "reitrn.",
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "reitrn-warehouse-setup.exe"
    },
    "nsis": {
      "oneClick": true,
      "runAfterFinish": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "printer.js",
      "settings-preload.js",
      "settings/**/*",
      "lock-preload.js",
      "lock/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}
